¿<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diagrama CRM → Ventas → MRP/ERP → Logística</title>
  <style>
    body {
      font-family: sans-serif;
      background: #f5f5f2;
      display: flex;
      justify-content: center;
      padding: 32px 16px;
      margin: 0;
    }
    svg { max-width: 680px; width: 100%; }

    /* Color ramps - light mode */
    .c-purple rect, .c-purple circle, .c-purple ellipse { fill: #EEEDFE; stroke: #534AB7; }
    .c-purple text { fill: #3C3489; }
    .c-gray rect, .c-gray circle, .c-gray ellipse { fill: #F1EFE8; stroke: #5F5E5A; }
    .c-gray text { fill: #444441; }
    .c-amber rect, .c-amber circle, .c-amber ellipse { fill: #FAEEDA; stroke: #854F0B; }
    .c-amber text { fill: #633806; }
    .c-teal rect, .c-teal circle, .c-teal ellipse { fill: #E1F5EE; stroke: #0F6E56; }
    .c-teal text { fill: #085041; }
    .c-coral rect, .c-coral circle, .c-coral ellipse { fill: #FAECE7; stroke: #993C1D; }
    .c-coral text { fill: #712B13; }
    .c-blue rect, .c-blue circle, .c-blue ellipse { fill: #E6F1FB; stroke: #185FA5; }
    .c-blue text { fill: #0C447C; }

    .arr { stroke: #888780; stroke-width: 1.5; fill: none; }
    .t  { font-size: 14px; font-weight: 400; fill: #2C2C2A; font-family: sans-serif; }
    .ts { font-size: 12px; font-weight: 400; fill: #5F5E5A; font-family: sans-serif; }
    .th { font-size: 14px; font-weight: 500; fill: #2C2C2A; font-family: sans-serif; }

    /* Dark mode */
    @media (prefers-color-scheme: dark) {
      body { background: #1a1a18; }
      .c-purple rect, .c-purple circle, .c-purple ellipse { fill: #3C3489; stroke: #AFA9EC; }
      .c-purple text { fill: #CECBF6; }
      .c-gray rect, .c-gray circle, .c-gray ellipse { fill: #444441; stroke: #B4B2A9; }
      .c-gray text { fill: #D3D1C7; }
      .c-amber rect, .c-amber circle, .c-amber ellipse { fill: #633806; stroke: #EF9F27; }
      .c-amber text { fill: #FAC775; }
      .c-teal rect, .c-teal circle, .c-teal ellipse { fill: #085041; stroke: #5DCAA5; }
      .c-teal text { fill: #9FE1CB; }
      .c-coral rect, .c-coral circle, .c-coral ellipse { fill: #712B13; stroke: #F0997B; }
      .c-coral text { fill: #F5C4B3; }
      .c-blue rect, .c-blue circle, .c-blue ellipse { fill: #0C447C; stroke: #85B7EB; }
      .c-blue text { fill: #B5D4F4; }
      .arr { stroke: #B4B2A9; }
      .t  { fill: #F1EFE8; }
      .ts { fill: #B4B2A9; }
      .th { fill: #F1EFE8; }
    }
  </style>
</head>
<body>
<svg width="100%" viewBox="0 0 680 1820" xmlns="http://www.w3.org/2000/svg">
<defs>
  <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
    <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </marker>
</defs>

<!-- CRM -->
<g class="c-purple">
  <rect x="240" y="20" width="200" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="42" text-anchor="middle" dominant-baseline="central">CRM</text>
</g>
<line x1="340" y1="64" x2="340" y2="88" class="arr" marker-end="url(#arrow)"/>

<!-- Prospecto -->
<g class="c-gray">
  <rect x="240" y="88" width="200" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="110" text-anchor="middle" dominant-baseline="central">Prospecto</text>
</g>
<line x1="340" y1="132" x2="340" y2="156" class="arr" marker-end="url(#arrow)"/>

<!-- Actividades comerciales -->
<g class="c-gray">
  <rect x="210" y="156" width="260" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="178" text-anchor="middle" dominant-baseline="central">Actividades comerciales</text>
</g>
<line x1="340" y1="200" x2="340" y2="224" class="arr" marker-end="url(#arrow)"/>

<!-- Generar Cotización -->
<g class="c-gray">
  <rect x="220" y="224" width="240" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="246" text-anchor="middle" dominant-baseline="central">Generar cotización</text>
</g>
<line x1="340" y1="268" x2="340" y2="292" class="arr" marker-end="url(#arrow)"/>

<!-- Decision: Cotización ganada? -->
<g class="c-amber">
  <rect x="200" y="292" width="280" height="50" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="317" text-anchor="middle" dominant-baseline="central">¿Cotización ganada?</text>
</g>
<line x1="200" y1="317" x2="120" y2="317" class="arr" marker-end="url(#arrow)"/>
<text class="ts" x="158" y="308" text-anchor="middle">NO</text>
<g class="c-gray">
  <rect x="50" y="297" width="70" height="40" rx="20" stroke-width="0.5"/>
  <text class="th" x="85" y="317" text-anchor="middle" dominant-baseline="central">Fin</text>
</g>
<line x1="480" y1="317" x2="560" y2="317" class="arr" marker-end="url(#arrow)"/>
<text class="ts" x="522" y="308" text-anchor="middle">SI</text>
<line x1="560" y1="317" x2="560" y2="370" stroke="#888780" stroke-width="1.5" fill="none" marker-end="url(#arrow)"/>
<line x1="560" y1="370" x2="440" y2="370" stroke="#888780" stroke-width="1.5" fill="none" marker-end="url(#arrow)"/>

<!-- VENTAS -->
<g class="c-purple">
  <rect x="240" y="350" width="200" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="372" text-anchor="middle" dominant-baseline="central">VENTAS</text>
</g>
<line x1="340" y1="394" x2="340" y2="418" class="arr" marker-end="url(#arrow)"/>

<!-- Crear Pedido -->
<g class="c-gray">
  <rect x="230" y="418" width="220" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="440" text-anchor="middle" dominant-baseline="central">Crear pedido</text>
</g>
<line x1="340" y1="462" x2="340" y2="486" class="arr" marker-end="url(#arrow)"/>

<!-- Confirmar Pedido -->
<g class="c-gray">
  <rect x="220" y="486" width="240" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="508" text-anchor="middle" dominant-baseline="central">Confirmar pedido</text>
</g>
<line x1="340" y1="530" x2="340" y2="554" class="arr" marker-end="url(#arrow)"/>

<!-- MRP / ERP -->
<g class="c-purple">
  <rect x="240" y="554" width="200" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="576" text-anchor="middle" dominant-baseline="central">MRP / ERP</text>
</g>
<line x1="340" y1="598" x2="340" y2="622" class="arr" marker-end="url(#arrow)"/>

<!-- MRP analiza -->
<g class="c-gray">
  <rect x="190" y="622" width="300" height="56" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="643" text-anchor="middle" dominant-baseline="central">MRP analiza pedido</text>
  <text class="ts" x="340" y="663" text-anchor="middle" dominant-baseline="central">por cada partida</text>
</g>
<line x1="340" y1="678" x2="340" y2="702" class="arr" marker-end="url(#arrow)"/>

<!-- Decision: Inventario? -->
<g class="c-amber">
  <rect x="200" y="702" width="280" height="50" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="727" text-anchor="middle" dominant-baseline="central">¿Hay inventario?</text>
</g>
<line x1="200" y1="727" x2="120" y2="727" class="arr" marker-end="url(#arrow)"/>
<text class="ts" x="158" y="718" text-anchor="middle">SI</text>

<!-- Reservar stock -->
<g class="c-teal">
  <rect x="20" y="707" width="100" height="40" rx="8" stroke-width="0.5"/>
  <text class="th" x="70" y="727" text-anchor="middle" dominant-baseline="central">Reservar stock</text>
</g>
<line x1="480" y1="727" x2="560" y2="727" class="arr" marker-end="url(#arrow)"/>
<text class="ts" x="522" y="718" text-anchor="middle">NO</text>

<!-- Tipo producto -->
<g class="c-amber">
  <rect x="510" y="707" width="130" height="40" rx="8" stroke-width="0.5"/>
  <text class="th" x="575" y="727" text-anchor="middle" dominant-baseline="central">Tipo producto</text>
</g>

<!-- Branch to COMPRA -->
<line x1="510" y1="727" x2="170" y2="727" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="170" y1="727" x2="170" y2="790" class="arr" marker-end="url(#arrow)"/>
<!-- Branch to PRODUCCIÓN -->
<line x1="575" y1="747" x2="575" y2="790" class="arr" marker-end="url(#arrow)"/>

<!-- COMPRA box -->
<g class="c-coral">
  <rect x="70" y="790" width="200" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="170" y="812" text-anchor="middle" dominant-baseline="central">COMPRA</text>
</g>

<!-- PRODUCCIÓN box -->
<g class="c-blue">
  <rect x="410" y="790" width="200" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="510" y="812" text-anchor="middle" dominant-baseline="central">PRODUCCIÓN</text>
</g>

<!-- COMPRA flow -->
<line x1="170" y1="834" x2="170" y2="858" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="50" y="858" width="240" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="170" y="880" text-anchor="middle" dominant-baseline="central">MRP genera solicitud compra</text>
</g>
<line x1="170" y1="902" x2="170" y2="926" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="60" y="926" width="220" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="170" y="948" text-anchor="middle" dominant-baseline="central">Aprobación solicitud</text>
</g>
<line x1="170" y1="970" x2="170" y2="994" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="60" y="994" width="220" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="170" y="1016" text-anchor="middle" dominant-baseline="central">Generar orden de compra</text>
</g>
<line x1="170" y1="1038" x2="170" y2="1062" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="60" y="1062" width="220" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="170" y="1084" text-anchor="middle" dominant-baseline="central">Recepción proveedor</text>
</g>
<line x1="170" y1="1106" x2="170" y2="1130" class="arr" marker-end="url(#arrow)"/>
<g class="c-teal">
  <rect x="60" y="1130" width="220" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="170" y="1152" text-anchor="middle" dominant-baseline="central">Entrada inventario</text>
</g>

<!-- PRODUCCIÓN flow -->
<line x1="510" y1="834" x2="510" y2="858" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="390" y="858" width="240" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="510" y="880" text-anchor="middle" dominant-baseline="central">Revisar componentes</text>
</g>
<line x1="510" y1="902" x2="510" y2="926" class="arr" marker-end="url(#arrow)"/>
<g class="c-amber">
  <rect x="370" y="926" width="280" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="510" y="948" text-anchor="middle" dominant-baseline="central">¿Componentes disponibles?</text>
</g>

<!-- SI branch prod -->
<line x1="370" y1="948" x2="410" y2="948" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="410" y1="948" x2="410" y2="994" class="arr" marker-end="url(#arrow)"/>
<text class="ts" x="388" y="940" text-anchor="middle">SI</text>
<!-- NO branch prod -->
<line x1="650" y1="948" x2="650" y2="970" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="650" y1="970" x2="612" y2="970" class="arr" marker-end="url(#arrow)"/>
<text class="ts" x="658" y="940" text-anchor="middle">NO</text>

<!-- NO compra componentes -->
<g class="c-gray">
  <rect x="520" y="994" width="130" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="585" y="1016" text-anchor="middle" dominant-baseline="central">Sol. compra comp.</text>
</g>
<line x1="585" y1="970" x2="585" y2="994" class="arr" marker-end="url(#arrow)"/>
<line x1="585" y1="1038" x2="585" y2="1062" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="520" y="1062" width="130" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="585" y="1084" text-anchor="middle" dominant-baseline="central">Aprobación</text>
</g>
<line x1="585" y1="1106" x2="585" y2="1130" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="520" y="1130" width="130" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="585" y="1152" text-anchor="middle" dominant-baseline="central">Orden compra</text>
</g>
<line x1="585" y1="1174" x2="585" y2="1198" class="arr" marker-end="url(#arrow)"/>
<g class="c-teal">
  <rect x="520" y="1198" width="130" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="585" y="1220" text-anchor="middle" dominant-baseline="central">Entrada inventario</text>
</g>
<line x1="585" y1="1242" x2="585" y2="1280" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="585" y1="1280" x2="510" y2="1280" class="arr" marker-end="url(#arrow)"/>

<!-- SI path joins gen orden producción -->
<line x1="410" y1="1038" x2="410" y2="1280" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="410" y1="1280" x2="432" y2="1280" class="arr" marker-end="url(#arrow)"/>

<!-- Gen orden producción -->
<g class="c-blue">
  <rect x="380" y="1262" width="260" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="510" y="1284" text-anchor="middle" dominant-baseline="central">Generar orden producción</text>
</g>
<line x1="510" y1="1306" x2="510" y2="1330" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="420" y="1330" width="180" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="510" y="1352" text-anchor="middle" dominant-baseline="central">Fabricar</text>
</g>
<line x1="510" y1="1374" x2="510" y2="1398" class="arr" marker-end="url(#arrow)"/>
<g class="c-teal">
  <rect x="390" y="1398" width="240" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="510" y="1420" text-anchor="middle" dominant-baseline="central">Entrada inventario</text>
</g>

<!-- Merge paths to Pedido completo -->
<line x1="170" y1="1174" x2="170" y2="1460" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="170" y1="1460" x2="270" y2="1460" class="arr" marker-end="url(#arrow)"/>
<line x1="510" y1="1442" x2="510" y2="1460" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="510" y1="1460" x2="410" y2="1460" class="arr" marker-end="url(#arrow)"/>

<!-- Reservar stock merge -->
<line x1="70" y1="727" x2="30" y2="727" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="30" y1="727" x2="30" y2="1460" stroke="#888780" stroke-width="1" fill="none"/>
<line x1="30" y1="1460" x2="230" y2="1460" class="arr" marker-end="url(#arrow)"/>

<!-- Pedido completo -->
<g class="c-teal">
  <rect x="230" y="1440" width="220" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="1462" text-anchor="middle" dominant-baseline="central">Pedido completo</text>
</g>
<line x1="340" y1="1484" x2="340" y2="1508" class="arr" marker-end="url(#arrow)"/>

<!-- LOGÍSTICA -->
<g class="c-purple">
  <rect x="240" y="1508" width="200" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="1530" text-anchor="middle" dominant-baseline="central">LOGÍSTICA</text>
</g>
<line x1="340" y1="1552" x2="340" y2="1576" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="230" y="1576" width="220" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="1598" text-anchor="middle" dominant-baseline="central">Preparar entrega</text>
</g>
<line x1="340" y1="1620" x2="340" y2="1644" class="arr" marker-end="url(#arrow)"/>
<g class="c-gray">
  <rect x="265" y="1644" width="150" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="1666" text-anchor="middle" dominant-baseline="central">Entrega</text>
</g>
<line x1="340" y1="1688" x2="340" y2="1712" class="arr" marker-end="url(#arrow)"/>
<g class="c-teal">
  <rect x="220" y="1712" width="240" height="44" rx="8" stroke-width="0.5"/>
  <text class="th" x="340" y="1734" text-anchor="middle" dominant-baseline="central">Pedido entregado</text>
</g>

</svg>
</body>
</html>